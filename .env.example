# kg-core environment — copy to .env.local and fill in. NEVER commit real values.
# HARD RULE: none of these may ever point at Supabase project vlezoyalutexenbnzzui
# (the shared BKG/Orchid/Tox production instance). kg-core uses its own project.

# Supabase (new dedicated dev project — NOT the shared prod instance)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth0
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_SECRET=

# Address normalization
GOOGLE_PLACES_KEY=

# Anthropic — powers NL quick capture (/api/capture). Without a key the box
# still works via a clearly-labeled heuristic parser for simple sentences.
ANTHROPIC_API_KEY=
# Optional model override for capture parsing (default: claude-sonnet-5)
ANTHROPIC_MODEL=

# Data layer. Server routes talk Postgres directly with RLS enforced per
# request. Defaults to the local dev cluster from scripts/db-dev.sh; later,
# point it at the dedicated dev Supabase project's connection string.
DATABASE_URL=postgres://postgres@localhost:55432/kg_core_dev

# Local development without secrets: maps the session to the seeded fixture
# admin. Only meaningful against a database seeded with the fixture. Never
# set in any deployed environment.
DEV_BYPASS=true
DEV_BYPASS_SUB=auth0|harborline-admin
